
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  decks     Deck[]   // 用户创建的卡组
  cards     Card[]   // 用户拥有的卡片
  logs      ReviewLog[] // 复习记录
  outputPracticeLogs OutputPracticeLog[] // 输出练习记录
  
  @@unique([email])
  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// 关系表：卡片-卡组 多对多关系
model CardDeck {
  cardId     String
  deckId     String

  card       Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  deck       Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@id([cardId, deckId])
  @@index([cardId])
  @@index([deckId])
}

// 3. 卡组表 (Deck) - 类似于文件夹，比如 "英语四级", "前端面试题"
model Deck {
  id          String   @id @default(cuid())
  title       String
  description String?
  color       String   @default("#137fec") // 标签颜色 (hex) - 必填
  isPublic    Boolean  @default(false) // 是否公开给其他人使用
  deletedAt   DateTime? // 软删除时间戳 (null = 未删除)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  cardDecks   CardDeck[]

  // 在同一个 userId 下，title 不能重复。
  // 但是不同用户可以使用相同的 title。
  @@unique([userId, title])
}

// 4. 卡片表 (Card) - ★★★ 最核心的部分 ★★★
model Card {
  id          String   @id @default(cuid())
  cardType    CardType @default(FLASHCARD) // 卡片类型

  // 闪卡字段
  front       String   // 卡片正面（问题），支持 Markdown 或 HTML
  back        String   // 卡片背面（答案）
  note        String?  // 助记提示

  // 文章卡片专用字段
  articleTitle String?  @db.Text // 文章标题
  articleContent String? @db.Text // 文章 Markdown 内容
  recallBlocks  Json?    // 主动回忆记忆块数据
  wordCount     Int?     // 字数统计
  readTimeMins  Int?     // 预计阅读时间（分钟）

  // 文章学习元数据
  totalStudyTimeMs Int? @default(0) // 总学习时间（毫秒）
  lastStudyAt     DateTime? // 最后学习时间

  // --- 艾宾浩斯/SM-2 算法所需字段 ---
  
  // 下一次需要复习的具体时间点
  // 查询时：SELECT * FROM Card WHERE nextReviewAt <= NOW()
  nextReviewAt DateTime @default(now()) 

  // 当前间隔天数 (Interval)
  // 比如：1天后复习，3天后复习，7天后复习...
  interval     Int      @default(0)

  // 熟悉度因子 (Ease Factor / E-Factor)
  // 默认通常为 2.5。数值越高，间隔增长越快（代表越容易记住）
  // 数值越低，间隔增长越慢（代表这个知识点很难）
  easeFactor   Float    @default(2.5)

  // 连续正确次数 (Repetitions)
  // 用于判断是否是"新卡片"或者"熟练卡片"
  repetitions  Int      @default(0)

  // 输出练习连续正确次数 (Output Repetitions)
  // 用于跟踪翻译/造句等输出练习的熟练度
  outputRepetitions Int @default(0)

  // --- 输出轨道 SM-2 状态 (当 repetitions >= 3 后激活) ---
  outputInterval     Int       @default(0)   // 输出轨道间隔天数
  outputEaseFactor   Float     @default(2.5) // 输出轨道易记因子
  outputNextReviewAt DateTime?               // 输出轨道下次复习时间 (null = 未激活)

  // 卡片状态
  state        CardState @default(NEW)

  // --- 关系 ---
  cardDecks    CardDeck[]
  outputExercise OutputExercise? // 关联输出练习数据
  outputPracticeLogs OutputPracticeLog[] // 输出练习日志

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  logs        ReviewLog[] // 关联历史复习记录

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, nextReviewAt]) // 建立索引，加速查询"今天需要复习的卡片"
  @@index([userId, createdAt]) // 索引：按创建时间排序
  @@index([userId, easeFactor]) // 索引：按熟悉度排序
}

// 5. 输出练习表 (OutputExercise) - 缓存AI生成的练习题
model OutputExercise {
  id        String   @id @default(cuid())

  // 关联的卡片
  cardId    String   @unique
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  // 目标词汇（从 card.front 提取）
  targetWord String

  // 示例句子（Level 1-4 共用）
  englishSentence String // 完整英文句子
  chineseSentence String // 中文翻译

  // Level 1: 填空题（英语句子，目标词用 _____ 替代）
  fillBlankTemplate String

  // Level 2: 连词成句（单词数组，按正确顺序）
  wordList Json // string[]

  // Level 3-4: AI 评估用标准答案
  standardAnswer String // 标准翻译参考

  // Level 4: 情景造句提示
  contextPrompt String // 情景描述

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practiceLogs OutputPracticeLog[] // 关联的练习记录

  @@index([cardId])
}

// 6. 输出练习日志表 (OutputPracticeLog) - 记录用户输出练习历史
model OutputPracticeLog {
  id        String   @id @default(cuid())

  // 关联
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  exerciseId String
  exercise  OutputExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  // 练习信息
  level     Int // 1=填空, 2=连词, 3=翻译, 4=情景
  isCorrect Boolean // 是否正确（Level 1-2 自动判断，3-4 用户自评）

  // 用户答案
  userAnswer String @db.Text

  // AI 反馈（Level 3-4）
  aiVocabScore Int? // 词汇使用评分 0-100
  aiGrammarScore Int? // 语法正确性评分 0-100
  aiNativeScore Int? // 地道表达评分 0-100
  aiFeedback String? @db.Text // AI 反馈文本
  aiSuggestedAnswer String? @db.Text // AI 建议的更好答案

  practicedAt DateTime @default(now())

  @@index([cardId])
  @@index([userId])
  @@index([exerciseId])
}

// 7. 复习日志表 (ReviewLog) - 用于生成"热力图"或分析记忆情况
model ReviewLog {
  id           String   @id @default(cuid())
  rating       Int      // 用户评分：1(忘记), 2(困难), 3(一般), 4(简单)
  reviewTime   Int      // 用户思考耗时（毫秒），用于分析卡片难度

  reviewedAt   DateTime @default(now()) // 实际复习时间

  // 记录复习时的算法状态（快照），方便后续分析算法优劣
  scheduledDays Int     // 计划间隔
  elapsedDays   Int     // 实际间隔（用户可能拖延了几天才复习）
  lastEaseFactor Float
  newEaseFactor  Float

  cardId       String
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  userId       String
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId]) // 索引：统计用户复习记录
  @@index([userId, rating]) // 索引：计算用户留存率
}

// 枚举：卡片类型
enum CardType {
  FLASHCARD  // 传统问答闪卡
  ARTICLE    // 文章学习卡片
}

// 枚举：卡片状态
enum CardState {
  NEW        // 新卡片，还没学过
  LEARNING   // 正在学习中（短时间内多次重复）
  REVIEW     // 进入复习队列（间隔按天计算）
  RELEARNING // 忘记了，重新学习（惩罚机制）
}
