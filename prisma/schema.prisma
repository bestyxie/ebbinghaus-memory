// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 2. 用户表
model User {
  id        String   @id @default(cuid()) // 使用 CUID 比自增 ID 更安全
  email     String   @unique
  name      String?
  password  String   // 存哈希后的密码
  createdAt DateTime @default(now())
  
  decks     Deck[]   // 用户创建的卡组
  cards     Card[]   // 用户拥有的卡片
  logs      ReviewLog[] // 复习记录
}

// 关系表：卡片-卡组 多对多关系
model CardDeck {
  cardId     String
  deckId     String

  card       Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  deck       Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@id([cardId, deckId])
  @@index([cardId])
  @@index([deckId])
}

// 3. 卡组表 (Deck) - 类似于文件夹，比如 "英语四级", "前端面试题"
model Deck {
  id          String   @id @default(cuid())
  title       String
  description String?
  color       String   @default("#137fec") // 标签颜色 (hex) - 必填
  isPublic    Boolean  @default(false) // 是否公开给其他人使用
  deletedAt   DateTime? // 软删除时间戳 (null = 未删除)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  cardDecks   CardDeck[]

  // 在同一个 userId 下，title 不能重复。
  // 但是不同用户可以使用相同的 title。
  @@unique([userId, title])
}

// 4. 卡片表 (Card) - ★★★ 最核心的部分 ★★★
model Card {
  id          String   @id @default(cuid())
  front       String   // 卡片正面（问题），支持 Markdown 或 HTML
  back        String   // 卡片背面（答案）
  note        String?  // 助记提示
  
  // --- 艾宾浩斯/SM-2 算法所需字段 ---
  
  // 下一次需要复习的具体时间点
  // 查询时：SELECT * FROM Card WHERE nextReviewAt <= NOW()
  nextReviewAt DateTime @default(now()) 

  // 当前间隔天数 (Interval)
  // 比如：1天后复习，3天后复习，7天后复习...
  interval     Int      @default(0)

  // 熟悉度因子 (Ease Factor / E-Factor)
  // 默认通常为 2.5。数值越高，间隔增长越快（代表越容易记住）
  // 数值越低，间隔增长越慢（代表这个知识点很难）
  easeFactor   Float    @default(2.5)

  // 连续正确次数 (Repetitions)
  // 用于判断是否是"新卡片"或者"熟练卡片"
  repetitions  Int      @default(0)

  // 卡片状态
  state        CardState @default(NEW)

  // --- 关系 ---
  cardDecks    CardDeck[]

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  logs        ReviewLog[] // 关联历史复习记录

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, nextReviewAt]) // 建立索引，加速查询"今天需要复习的卡片"
  @@index([userId, createdAt]) // 索引：按创建时间排序
  @@index([userId, easeFactor]) // 索引：按熟悉度排序
}

// 5. 复习日志表 (ReviewLog) - 用于生成"热力图"或分析记忆情况
model ReviewLog {
  id           String   @id @default(cuid())
  rating       Int      // 用户评分：1(忘记), 2(困难), 3(一般), 4(简单)
  reviewTime   Int      // 用户思考耗时（毫秒），用于分析卡片难度
  
  reviewedAt   DateTime @default(now()) // 实际复习时间
  
  // 记录复习时的算法状态（快照），方便后续分析算法优劣
  scheduledDays Int     // 计划间隔
  elapsedDays   Int     // 实际间隔（用户可能拖延了几天才复习）
  lastEaseFactor Float
  newEaseFactor  Float
  
  cardId       String
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  
  userId       String
  user         User     @relation(fields: [userId], references: [id])
}

// 枚举：卡片状态
enum CardState {
  NEW        // 新卡片，还没学过
  LEARNING   // 正在学习中（短时间内多次重复）
  REVIEW     // 进入复习队列（间隔按天计算）
  RELEARNING // 忘记了，重新学习（惩罚机制）
}
